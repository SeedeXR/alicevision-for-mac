{
  "name": "ai-segmentation",
  "version": "2.0.0",
  "description": "AI-powered foreground segmentation via BiRefNet on CoreML (CPU + Metal GPU)",
  "license": "MIT",
  "compute_backends": ["coreml", "metal", "cpu"],
  "models_dir": "../../ai-models",
  "python": {
    "venv": "../../meshroom-venv",
    "nodes_path": "nodes",
    "package_path": "python",
    "entry_module": "meshroom.bin.node_run"
  },
  "nodes": [
    {
      "name": "SegmentationBiRefNet",
      "icon": "wand.and.stars.inverse",
      "category": "Utils",
      "inputs": {
        "input": "file",
        "modelVariant": "string",
        "maskFormat": "string",
        "keepFilename": "bool",
        "verboseLevel": "string"
      },
      "outputs": {
        "output": "file"
      },
      "constant_flags": ["--nodeType", "SegmentationBiRefNet"],
      "parallelization": null
    }
  ],
  "model_variants": [
    {"id": "birefnet-lite", "size_mb": 90, "backbone": "swin_v1_t", "package": "BiRefNet_lite.mlpackage"},
    {"id": "birefnet-general", "size_mb": 447, "backbone": "swin_v1_l", "package": "BiRefNet.mlpackage"}
  ]
}
