{
  "name": "ai-segmentation",
  "version": "1.0.0",
  "description": "AI-powered foreground segmentation via BiRefNet + CoreML",
  "license": "MIT",
  "compute_backends": ["coreml", "metal", "ane", "cpu"],
  "models_dir": "../../ai-models",
  "python": {
    "venv": "../../meshroom-venv",
    "nodes_path": "nodes",
    "package_path": "python",
    "entry_module": "meshroom.bin.node_run"
  },
  "wrapper_script": "../../meshroom-native/scripts/run_python_node.sh",
  "nodes": [
    {
      "name": "SegmentationBiRefNet",
      "icon": "wand.and.stars.inverse",
      "category": "Utils",
      "inputs": {
        "input": "file",
        "modelVariant": "string",
        "outputResolution": "string",
        "alphaMatting": "bool",
        "maskFormat": "string",
        "keepFilename": "bool",
        "verboseLevel": "string"
      },
      "outputs": {
        "output": "file"
      },
      "constant_flags": ["--nodeType", "SegmentationBiRefNet"],
      "parallelization": null
    }
  ],
  "model_variants": [
    {"id": "birefnet-general", "size_mb": 927, "backbone": "swin_v1_large"},
    {"id": "birefnet-dis", "size_mb": 929, "backbone": "swin_v1_large_dis"},
    {"id": "birefnet-lite", "size_mb": 213, "backbone": "swin_v1_tiny"}
  ]
}
